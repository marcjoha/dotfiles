" ==============================================================================
" SOLARIZED COLOR SYSTEM CONFIGURATION
" ==============================================================================
"
" We support two ways of rendering Solarized in Ghostty:
"
"   METHOD 1 (Default): True 24-Bit Color (TrueColor)
"   - Uses standard Solarized hex codes (#002b36 base) independent of terminal.
"   - Requires 'termguicolors' to be supported and set.
"
"   METHOD 2: Terminal-Native (16-Color Mode)
"   - Uses Ghostty's custom 'Solarized Dark Higher Contrast' palette (0-15) and
"     background (#001e27).
"   - Guarantees 100% color matching and native rendering (excellent inside tmux).
"   - To use, uncomment 'let g:solarized_use16 = 1' and comment out 'set termguicolors'.
"
" ==============================================================================

" --- Theme Customization Variables ---
" Background transparency: 1 = Transparent (uses Ghostty's background), 0 = Solid (classic Solarized #002b36 background)
let g:solarized_termtrans = 1

" Contrast/visibility level: 'normal', 'high', or 'low'
let g:solarized_visibility = 'high'

" Uncomment below to force Vim to use Ghostty's custom 16-color palette (Method 2)
" let g:solarized_use16 = 1

" --- Color Engine Initialization ---
if exists('g:solarized_use16') && g:solarized_use16 == 1
  " Method 2: Use Terminal's Native 16-Color Palette
  set notermguicolors
  let g:solarized_termcolors = 16
else
  " Method 1: True 24-Bit Color (TrueColor)
  if has('termguicolors')
    set termguicolors
    " Define manual 24-bit terminal overrides for Apple's standard Vim in modern terms/tmux
    let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
    let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
  endif
endif

syntax on
set background=dark

" Load the modern TrueColor-compatible Solarized 8 colorscheme
silent! colorscheme solarized8

if !exists('g:colors_name') || g:colors_name != 'solarized8'
  " Fallback to classic solarized if solarized8 is unavailable
  let g:solarized_termcolors = 16
  silent! colorscheme solarized
endif

" Tab and indentation settings
set tabstop=2             " number of visual spaces per TAB
set softtabstop=2         " number of spaces in tab when editing
set expandtab             " tabs are spaces
filetype indent on        " load filetype-specific indent files

" Display settings
set number                " show line numbers
set showcmd               " show command in bottom bar
set wildmenu              " visual autocomplete for command menu
set lazyredraw            " redraw only when we need to.
set showmatch             " highlight matching [{()}]

" Search settings
set incsearch             " search as characters are entered
set nohlsearch            " don't highlight matches

" Interface and editor behavior
set mouse=a               " allows for highlighting text with mouse
set clipboard=unnamedplus " copy Vim's yank-stuff into system clipboard

" Fix backspace keys so it behaves intuitively in insert mode
set backspace=indent,eol,start

" Disable annoying local swap/backup files in project directories
set nobackup
set nowritebackup
set noswapfile
